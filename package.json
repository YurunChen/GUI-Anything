{
  "name": "gui-anything",
  "version": "0.1.0",
  "description": "A sidecar observer and memory layer for Claude Code flow sessions.",
  "type": "module",
  "private": true,
  "bin": {
    "ga": "cli/ga.mjs"
  },
  "files": [
    "cli",
    "!cli/**/*.test.mjs",
    "scripts",
    "skills",
    "scheme/src",
    "scheme/bun.lock",
    "scheme/package.json",
    "scheme/tsconfig.json",
    "!scheme/src/**/*.test.ts",
    "!scheme/src/**/*.test.tsx",
    "!scheme/src/services/notification/weixin-service/.venv",
    "!scheme/src/services/notification/weixin-service/__pycache__",
    "!scheme/src/services/notification/weixin-service/data",
    "!scheme/src/services/notification/weixin-service/*.log",
    "assets/demo",
    "assets/logo.png",
    "README.md",
    "README_CN.md",
    "CONTRIBUTING.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "node --test cli/**/*.test.mjs",
    "smoke": "node ./cli/ga.mjs --help",
    "verify": "npm run test && npm run smoke"
  },
  "license": "MIT"
}
